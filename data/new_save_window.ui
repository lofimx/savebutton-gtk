<?xml version='1.0' encoding='UTF-8'?>
<interface>
  <requires lib="gio" version="2.0"/>
  <requires lib="gtk" version="4.14"/>
  <requires lib="libadwaita" version="1.5"/>
  <template class="Gjs_NewSaveWindow" parent="AdwWindow">
    <property name="content">
      <object class="AdwToastOverlay" id="toastOverlay">
        <property name="child">
          <object class="AdwToolbarView">
            <child type="top">
              <object class="AdwHeaderBar">
                <child type="start">
                  <object class="GtkButton" id="cancelButton">
                    <property name="label" translatable="yes">Cancel</property>
                  </object>
                </child>
                <property name="title-widget">
                  <object class="AdwWindowTitle">
                    <property name="title" translatable="yes">New Save</property>
                  </object>
                </property>
                <child type="end">
                  <object class="GtkButton" id="saveButton">
                    <property name="label" translatable="yes">Save</property>
                    <style>
                      <class name="suggested-action"/>
                    </style>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkButton" id="openFileButton">
                    <property name="icon-name">document-open-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Open a File</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkStack" id="contentStack">
                <property name="vexpand">true</property>
                <!-- Form page -->
                <child>
                  <object class="GtkStackPage">
                    <property name="name">form</property>
                    <property name="child">
                      <object class="GtkScrolledWindow">
                        <property name="vexpand">true</property>
                        <property name="hscrollbar-policy">never</property>
                        <child>
                          <object class="AdwClamp">
                            <property name="maximum-size">500</property>
                            <property name="tightening-threshold">400</property>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <property name="margin-top">24</property>
                                <property name="margin-bottom">24</property>
                                <property name="margin-start">12</property>
                                <property name="margin-end">12</property>
                                <!-- Bookmark / blurb entry -->
                                <child>
                                  <object class="GtkEntry" id="angaText">
                                    <property name="placeholder-text" translatable="yes">Enter bookmark or blurb...</property>
                                    <property name="enable-emoji-completion">True</property>
                                  </object>
                                </child>
                                <!-- Tags: inline pills + entry in one card-styled box -->
                                <child>
                                  <object class="GtkBox" id="tagsContainer">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">4</property>
                                    <property name="hexpand">true</property>
                                    <style>
                                      <class name="tags-container"/>
                                    </style>
                                    <child>
                                      <object class="GtkEntry" id="tagsInput">
                                        <property name="placeholder-text" translatable="yes">Tags (comma separated)...</property>
                                        <property name="hexpand">true</property>
                                        <style>
                                          <class name="flat"/>
                                          <class name="tags-entry"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <!-- Notes (always visible) -->
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="GtkTextView" id="noteText">
                                        <property name="focusable">true</property>
                                        <property name="vexpand">true</property>
                                        <property name="wrap-mode">word-char</property>
                                        <property name="accepts-tab">False</property>
                                        <property name="top-margin">8</property>
                                        <property name="bottom-margin">8</property>
                                        <property name="left-margin">8</property>
                                        <property name="right-margin">8</property>
                                        <property name="height-request">80</property>
                                        <style>
                                          <class name="card"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Note (optional)</property>
                                        <property name="xalign">0</property>
                                        <style>
                                          <class name="dim-label"/>
                                          <class name="caption"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
                <!-- File preview page -->
                <child>
                  <object class="GtkStackPage">
                    <property name="name">file-preview</property>
                    <property name="child">
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">12</property>
                        <property name="margin-top">24</property>
                        <property name="margin-bottom">24</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <property name="vexpand">true</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <child>
                          <object class="GtkOverlay" id="filePreviewOverlay">
                            <child>
                              <object class="GtkBox" id="filePreviewContent">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <property name="halign">center</property>
                                <property name="valign">center</property>
                              </object>
                            </child>
                            <child type="overlay">
                              <object class="GtkButton" id="removeFileButton">
                                <property name="label" translatable="yes">Remove</property>
                                <property name="halign">end</property>
                                <property name="valign">start</property>
                                <property name="margin-top">6</property>
                                <property name="margin-end">6</property>
                                <style>
                                  <class name="destructive-action"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>
      </object>
    </property>
    <property name="default-height">500</property>
    <property name="default-width">450</property>
    <property name="width-request">360</property>
    <property name="height-request">400</property>
  </template>
</interface>
