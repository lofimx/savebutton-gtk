{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["jest", "node", "temporal-polyfill"],
    "skipLibCheck": true,
    "typeRoots": ["node_modules/@types"]
  },
  "include": ["gi-types/gi.d.ts", "types/*.d.ts", "tests/**/*", "src/**/*"],
  "exclude": ["node_modules"]
}
